<Window x:Class="WinDFIR.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:WinDFIR.UI.Views"
        xmlns:converters="clr-namespace:WinDFIR.UI.Converters"
        Title="HostWitness - Live Forensics &amp; Activity Correlation"
        Icon="pack://application:,,,/LOGOS/程式圖案.png"
        Height="700" Width="1400"
        FontSize="16"
        WindowStartupLocation="CenterScreen"
        Loaded="MainWindow_Loaded"
        Closing="MainWindow_Closing"
        KeyDown="MainWindow_KeyDown">
    <Window.Resources>
        <!-- Shared icons (window-level for main + detached toolbars) -->
        <Geometry x:Key="DetachIcon">M2,6 H12 V18 H2 Z M10,4 H20 V14 H10 Z M12,10 L10,10</Geometry>
        <Geometry x:Key="RestoreIcon">M2,6 H14 V18 H2 Z M10,4 H18 V10 H10 Z</Geometry>
        <Geometry x:Key="PlayIcon">M8,4 L8,20 L21,12 Z</Geometry>
        <ContextMenu x:Key="DynamicTabContextMenu" Opened="DynamicTabContextMenu_Opened">
            <MenuItem Name="DynamicTabDetachMenuItem" Header="Detach to Window" Click="DynamicTabDetachMenuItem_Click"/>
            <MenuItem Name="DynamicTabRestoreMenuItem" Header="Restore to Main Window" Click="DynamicTabRestoreMenuItem_Click" Visibility="Collapsed"/>
        </ContextMenu>
        <ContextMenu x:Key="StaticTabContextMenu" Opened="StaticTabContextMenu_Opened">
            <MenuItem Name="StaticTabDetachMenuItem" Header="Detach to Window" Click="StaticTabDetachMenuItem_Click"/>
            <MenuItem Name="StaticTabRestoreMenuItem" Header="Restore to Main Window" Click="StaticTabRestoreMenuItem_Click" Visibility="Collapsed"/>
        </ContextMenu>
        <!-- Detach/Restore icon driven by MainViewModel.IsDetachRestoreMode -->
        <Style x:Key="DetachRestorePathStyle" TargetType="Path">
            <Setter Property="Data" Value="{StaticResource DetachIcon}"/>
            <Setter Property="Fill" Value="#2B579A"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsDetachRestoreMode}" Value="True">
                    <Setter Property="Data" Value="{StaticResource RestoreIcon}"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Menu Bar -->
        <Menu Grid.Row="0">
            <MenuItem Header="_File">
                <MenuItem Header="_Open Snapshot..." Click="OpenSnapshotMenuItem_Click" ToolTip="Load timeline from an exported snapshot folder (timeline.json) — Ctrl+O"/>
                <MenuItem Header="Collection _Trust..." Name="CollectionTrustMenuItem" Click="CollectionTrustMenuItem_Click" Visibility="Collapsed" ToolTip="Show the red/amber/green collection-trust assessment for the open snapshot"/>
                <MenuItem Header="_Close Snapshot" Name="CloseSnapshotMenuItem" Click="CloseSnapshotMenuItem_Click" Visibility="Collapsed" ToolTip="Return timeline to live data — Ctrl+W"/>
                <Separator/>
                <MenuItem Header="_Export Snapshot" Click="ExportButton_Click" ToolTip="Export current index to Snapshot folder — Ctrl+E"/>
                <MenuItem Header="Export to _SQLite..." Click="ExportToSqliteMenuItem_Click" ToolTip="Export current timeline to a SQLite database for offline query"/>
                <MenuItem Header="_Open from SQLite..." Click="OpenFromSqliteMenuItem_Click" ToolTip="Load timeline from a SQLite database (created by Export to SQLite)"/>
                <MenuItem Header="Load Event Log (._evtx)..." Click="LoadEvtxMenuItem_Click" ToolTip="Parse one or more offline .evtx files (from a dead box, VSS copy, or another tool) into the current session"/>
                <MenuItem Header="Load _SRUM (SRUDB.dat)..." Click="LoadSrumMenuItem_Click" ToolTip="Parse a System Resource Usage Monitor database (SRUDB.dat) — per-app network and resource usage history. High-volume data."/>
                <MenuItem Header="Load _BITS (qmgr.db)..." Click="LoadBitsMenuItem_Click" ToolTip="Parse a BITS queue database (qmgr.db) — recovers download URLs and local paths from queued transfer jobs."/>
                <MenuItem Header="Load _WMI (OBJECTS.DATA)..." Click="LoadWmiMenuItem_Click" ToolTip="Parse a WMI CIM repository (OBJECTS.DATA) — recovers event-subscription persistence (filters/consumers/bindings) for triage."/>
                <Separator/>
                <MenuItem Header="Save _session now" Click="SaveSessionMenuItem_Click" ToolTip="Save current timeline to last session (restore on next start)"/>
                <MenuItem Header="Save _layout now" Click="SaveLayoutMenuItem_Click" ToolTip="Save window position, size, and tab selection"/>
                <MenuItem Header="_Restore default layout" Click="RestoreLayoutMenuItem_Click" ToolTip="Reset window layout to default (next start uses saved layout if present)"/>
                <Separator/>
                <MenuItem Header="E_xit" Click="ExitMenuItem_Click"/>
            </MenuItem>
            <MenuItem Header="_Advanced">
                <MenuItem Header="_Drill Down" Click="DrillDownButton_Click" Name="DrillDownMenuItem" ToolTip="From Live Process: show related events in Timeline — Ctrl+Shift+D"/>
                <MenuItem Name="RegistrySearchMenuItem" Header="Registry _Search..." Click="RegistrySearchMenuItem_Click" ToolTip="Re-run default registry queries or run a custom query (Value/Data pattern, Recursive). Results go to Timeline."/>
                <Separator/>
                <MenuItem Header="_Settings..." Click="SettingsMenuItem_Click"/>
            </MenuItem>
            <MenuItem Header="_Help">
                <MenuItem Header="Export _diagnostic info..." Click="ExportDiagnosticInfoMenuItem_Click" ToolTip="Save version, paths, and index stats to a text file"/>
                <MenuItem Header="_About" Click="AboutMenuItem_Click"/>
            </MenuItem>
        </Menu>

        <!-- Dynamic Analysis Tabs -->
        <TabControl Grid.Row="1" Name="DynamicTabControl" SelectionChanged="DynamicTabControl_SelectionChanged" Margin="5,5,5,0"
                    SelectedIndex="{Binding SelectedDynamicTabIndex, Mode=TwoWay}">
            <TabControl.Template>
                <ControlTemplate TargetType="TabControl">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TabPanel Grid.Row="0" IsItemsHost="True" Margin="0"/>
                    </Grid>
                </ControlTemplate>
            </TabControl.Template>
            <TabItem Header="Timeline View" Name="TimelineTab" Tag="Timeline" ContextMenu="{StaticResource DynamicTabContextMenu}"/>
            <TabItem Header="Live Stream" Name="LiveStreamTab" Tag="LiveStream" ContextMenu="{StaticResource DynamicTabContextMenu}"/>
            <TabItem Header="Live Process" Name="ProcessTab" Tag="Process" ContextMenu="{StaticResource DynamicTabContextMenu}"/>
            <TabItem Header="Live TCP View" Name="LiveTcpTab" Tag="LiveTcp" ContextMenu="{StaticResource DynamicTabContextMenu}"/>
        </TabControl>

        <!-- Static Analysis Tabs -->
        <TabControl Grid.Row="2" Name="StaticTabControl" SelectionChanged="StaticTabControl_SelectionChanged" Margin="5,0,5,0"
                    SelectedIndex="{Binding SelectedStaticTabIndex, Mode=TwoWay}">
            <TabControl.Template>
                <ControlTemplate TargetType="TabControl">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TabPanel Grid.Row="0" IsItemsHost="True" Margin="0"/>
                    </Grid>
                </ControlTemplate>
            </TabControl.Template>
            <TabItem Header="System Info" Name="SystemInfoTab" Tag="SystemInfo" ContextMenu="{StaticResource StaticTabContextMenu}"/>
            <TabItem Header="Process View" Name="StaticProcessTab" Tag="StaticProcess" ContextMenu="{StaticResource StaticTabContextMenu}"/>
            <TabItem Header="Recent Files" Name="RecentFilesTab" Tag="RecentFiles" ContextMenu="{StaticResource StaticTabContextMenu}"/>
            <TabItem Header="Prefetch" Name="PrefetchTab" Tag="Prefetch" ContextMenu="{StaticResource StaticTabContextMenu}"/>
            <TabItem Header="Amcache" Name="AmcacheTab" Tag="Amcache" ContextMenu="{StaticResource StaticTabContextMenu}"/>
            <TabItem Header="Autorun" Name="AutorunTab" Tag="Autorun" ContextMenu="{StaticResource StaticTabContextMenu}"/>
            <TabItem Header="Event Log" Name="EventLogTab" Tag="EventLog" ContextMenu="{StaticResource StaticTabContextMenu}"/>
            <TabItem Header="Netstat" Name="NetworkTab" Tag="Network" ContextMenu="{StaticResource StaticTabContextMenu}"/>
            <TabItem Header="Browsing History" Name="BrowsingHistoryTab" Tag="BrowsingHistory" ContextMenu="{StaticResource StaticTabContextMenu}"/>
            <TabItem Header="MFT" Name="MftTab" Tag="MFT" ContextMenu="{StaticResource StaticTabContextMenu}"/>
        </TabControl>

        <!-- Shared Content Area -->
        <Grid Grid.Row="3" Margin="5">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            
            <!-- Dynamic Toolbar (根據選中的標籤顯示對應的按鈕) -->
            <ToolBar Grid.Row="0" Name="DynamicToolBar" Margin="0,0,0,5">
                <ToolBar.Resources>
                    <Style TargetType="Button">
                        <Setter Property="Width" Value="52"/>
                        <Setter Property="Height" Value="52"/>
                        <Setter Property="Background" Value="#FFF0F4FF"/>
                        <Setter Property="BorderBrush" Value="#FF7A9CCF"/>
                        <Setter Property="BorderThickness" Value="1.5"/>
                        <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
                        <Setter Property="RenderTransform">
                            <Setter.Value>
                                <ScaleTransform ScaleX="1" ScaleY="1"/>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FFD6E6FF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#FFB8D4FF"/>
                                <Setter Property="BorderBrush" Value="#FF2B579A"/>
                                <Setter Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.9" ScaleY="0.9"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                    <Style TargetType="ToggleButton">
                        <Setter Property="Width" Value="52"/>
                        <Setter Property="Height" Value="52"/>
                        <Setter Property="Background" Value="#FFF0F4FF"/>
                        <Setter Property="BorderBrush" Value="#FF7A9CCF"/>
                        <Setter Property="BorderThickness" Value="1.5"/>
                        <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
                        <Setter Property="RenderTransform">
                            <Setter.Value>
                                <ScaleTransform ScaleX="1" ScaleY="1"/>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FFD6E6FF"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter Property="Background" Value="#FFB8D4FF"/>
                                <Setter Property="BorderBrush" Value="#FF2B579A"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#FF9EC4FF"/>
                                <Setter Property="BorderBrush" Value="#FF1E4F8F"/>
                                <Setter Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.9" ScaleY="0.9"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                    <Pen x:Key="ToolbarIconPen" Brush="#2B579A" Thickness="2" StartLineCap="Round" EndLineCap="Round" LineJoin="Round"/>
                    <!-- Trash can (垃圾桶): lid + body -->
                    <Geometry x:Key="ClearTrashCanGeometry">M5,4 H19 V6 H5 Z M7,6 V19 H17 V6 H7 Z</Geometry>
                    <Geometry x:Key="TcpIcon">M3,6 L21,6 L21,10 L3,10 Z M3,14 L21,14 L21,18 L3,18 Z</Geometry>
                    <Geometry x:Key="UdpIcon">M4,6 L20,6 L12,20 Z</Geometry>
                    <Geometry x:Key="RefreshIcon">M12,4 A8,8 0 1 1 4,12 M4,12 L6,10 M4,12 L6,14</Geometry>
                    <DrawingImage x:Key="ResolveIconImage">
                        <DrawingImage.Drawing>
                            <DrawingGroup>
                                <GeometryDrawing Brush="{x:Null}" Pen="{StaticResource ToolbarIconPen}" Geometry="M2,4 H22 V15 H2 Z"/>
                                <GeometryDrawing Brush="#2B579A" Geometry="M2,4 H22 V7 H2 Z"/>
                                <GeometryDrawing Brush="{x:Null}" Pen="{StaticResource ToolbarIconPen}" Geometry="M16,18 A3,3 0 1 1 22,18 A3,3 0 1 1 16,18"/>
                                <GeometryDrawing Brush="{x:Null}" Pen="{StaticResource ToolbarIconPen}" Geometry="M19,15 L19,21 M16,18 L22,18 M17.5,15.5 L20.5,20.5"/>
                            </DrawingGroup>
                        </DrawingImage.Drawing>
                    </DrawingImage>
                    <DrawingImage x:Key="StateIconImage">
                        <DrawingImage.Drawing>
                            <DrawingGroup>
                                <GeometryDrawing Brush="{x:Null}" Pen="{StaticResource ToolbarIconPen}" Geometry="M3,6 H9 V12 H3 Z"/>
                                <GeometryDrawing Brush="{x:Null}" Pen="{StaticResource ToolbarIconPen}" Geometry="M3,13 H9 V19 H3 Z"/>
                                <GeometryDrawing Brush="{x:Null}" Pen="{StaticResource ToolbarIconPen}" Geometry="M11,9 H21 M11,16 H21"/>
                                <GeometryDrawing Brush="{x:Null}" Pen="{StaticResource ToolbarIconPen}" Geometry="M4.5,9 L6,10.5 L8,7.8"/>
                            </DrawingGroup>
                        </DrawingImage.Drawing>
                    </DrawingImage>
                    <Style x:Key="ClearIconStyle" TargetType="Path">
                        <Setter Property="Fill" Value="#2B579A"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=IsMouseOver}" Value="True">
                                <Setter Property="Fill" Value="#1F4E8C"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=IsPressed}" Value="True">
                                <Setter Property="Fill" Value="#16325A"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                    <Style x:Key="RefreshIconStyle" TargetType="Path">
                        <Setter Property="Stroke" Value="#2E7D32"/>
                        <Setter Property="StrokeThickness" Value="2.6"/>
                        <Setter Property="StrokeStartLineCap" Value="Round"/>
                        <Setter Property="StrokeEndLineCap" Value="Round"/>
                        <Setter Property="StrokeLineJoin" Value="Round"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=IsMouseOver}" Value="True">
                                <Setter Property="Stroke" Value="#246B2A"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=IsPressed}" Value="True">
                                <Setter Property="Stroke" Value="#1B4F20"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ToolBar.Resources>
                <!-- Toolbar visibility driven by MainViewModel.ToolbarViewType -->
                <!-- Timeline View Buttons -->
                <Button Name="TimelineStartButton" Click="StartButton_Click" Margin="5,0" ToolTip="Play/Pause"
                        Visibility="{Binding ToolbarViewType, Converter={StaticResource ToolbarViewTypeToVisibilityConverter}, ConverterParameter=Timeline}">
                    <Path Data="M8,4 L8,20 L21,12 Z" Fill="Black" Stretch="Uniform"/>
                </Button>
                <Button Name="TimelineClearButton" Click="TimelineClearButton_Click" Margin="5,0" ToolTip="Clear timeline filters and range (Ctrl+L)"
                        Visibility="{Binding ToolbarViewType, Converter={StaticResource ToolbarViewTypeToVisibilityConverter}, ConverterParameter=Timeline}">
                    <Path Data="{StaticResource ClearTrashCanGeometry}" Style="{StaticResource ClearIconStyle}" Stretch="Uniform"/>
                </Button>
                <Button Name="DynamicDetachButton" Click="DynamicDetachButton_Click" Margin="10,0,5,0"
                        ToolTip="{Binding DetachButtonToolTip}"
                        Visibility="{Binding ToolbarViewType, Converter={StaticResource ToolbarViewTypeToVisibilityConverter}, ConverterParameter=Timeline|LiveStream|Process|LiveTcp|StaticProcess|Network|Static}">
                    <Path x:Name="DetachButtonIcon" Style="{StaticResource DetachRestorePathStyle}" Stretch="Uniform" Width="18" Height="18"/>
                </Button>
                
                <!-- Live Stream Buttons -->
                <Button Name="LiveStreamStartButton" Click="StartButton_Click" Margin="5,0" ToolTip="Play/Pause"
                        Visibility="{Binding ToolbarViewType, Converter={StaticResource ToolbarViewTypeToVisibilityConverter}, ConverterParameter=LiveStream}">
                    <Path Data="M8,4 L8,20 L21,12 Z" Fill="Black" Stretch="Uniform"/>
                </Button>
                <Separator Margin="10,0" Name="LiveStreamClearSeparator"
                           Visibility="{Binding ToolbarViewType, Converter={StaticResource ToolbarViewTypeToVisibilityConverter}, ConverterParameter=LiveStream}"/>
                <Button Name="LiveStreamClearButton" Click="LiveStreamClearButton_Click" Margin="5,0" ToolTip="Clear"
                        Visibility="{Binding ToolbarViewType, Converter={StaticResource ToolbarViewTypeToVisibilityConverter}, ConverterParameter=LiveStream}">
                    <Path Data="{StaticResource ClearTrashCanGeometry}" Style="{StaticResource ClearIconStyle}" Stretch="Uniform"/>
                </Button>
                
                <!-- Process View Buttons -->
                <Button Name="ProcessStartButton" Click="StartButton_Click" Margin="5,0" ToolTip="Play/Pause"
                        Visibility="{Binding ToolbarViewType, Converter={StaticResource ToolbarViewTypeToVisibilityConverter}, ConverterParameter=Process}">
                    <Path Data="M8,4 L8,20 L21,12 Z" Fill="Black" Stretch="Uniform"/>
                </Button>
                <Button Name="ProcessRefreshButton" Click="ProcessRefreshButton_Click" Margin="5,0" ToolTip="Refresh"
                        Visibility="{Binding ToolbarViewType, Converter={StaticResource ToolbarViewTypeToVisibilityConverter}, ConverterParameter=Process}">
                    <Path Data="{StaticResource RefreshIcon}" Style="{StaticResource RefreshIconStyle}" Stretch="Uniform"/>
                </Button>
                <Button Name="ProcessClearButton" Click="ProcessClearButton_Click" Margin="5,0" ToolTip="Clear"
                        Visibility="{Binding ToolbarViewType, Converter={StaticResource ToolbarViewTypeToVisibilityConverter}, ConverterParameter=Process}">
                    <Path Data="{StaticResource ClearTrashCanGeometry}" Style="{StaticResource ClearIconStyle}" Stretch="Uniform"/>
                </Button>

                <!-- Live TCP View Buttons -->
                <Button Name="LiveTcpStartButton" Click="StartButton_Click" Margin="5,0" ToolTip="Play/Pause"
                        Visibility="{Binding ToolbarViewType, Converter={StaticResource ToolbarViewTypeToVisibilityConverter}, ConverterParameter=LiveTcp}">
                    <Path Data="M8,4 L8,20 L21,12 Z" Fill="Black" Stretch="Uniform"/>
                </Button>
                <Button Name="LiveTcpRefreshButton" Click="LiveTcpRefreshButton_Click" Margin="5,0" ToolTip="Refresh"
                        Visibility="{Binding ToolbarViewType, Converter={StaticResource ToolbarViewTypeToVisibilityConverter}, ConverterParameter=LiveTcp}">
                    <Path Data="{StaticResource RefreshIcon}" Style="{StaticResource RefreshIconStyle}" Stretch="Uniform"/>
                </Button>
                <Button Name="LiveTcpClearButton" Click="LiveTcpClearButton_Click" Margin="5,0" ToolTip="Clear"
                        Visibility="{Binding ToolbarViewType, Converter={StaticResource ToolbarViewTypeToVisibilityConverter}, ConverterParameter=LiveTcp}">
                    <Path Data="{StaticResource ClearTrashCanGeometry}" Style="{StaticResource ClearIconStyle}" Stretch="Uniform"/>
                </Button>
                <Separator Margin="10,0" Name="LiveTcpFilterSeparator"
                           Visibility="{Binding ToolbarViewType, Converter={StaticResource ToolbarViewTypeToVisibilityConverter}, ConverterParameter=LiveTcp}"/>
                <ToggleButton Name="LiveTcpResolveButton" Checked="LiveTcpResolveToggle_Checked" Unchecked="LiveTcpResolveToggle_Checked" Margin="5,0" ToolTip="Resolve IP/FQDN" Width="52" Height="52"
                        Visibility="{Binding ToolbarViewType, Converter={StaticResource ToolbarViewTypeToVisibilityConverter}, ConverterParameter=LiveTcp}">
                    <Image Source="{StaticResource ResolveIconImage}" Width="18" Height="18"/>
                </ToggleButton>
                <Button Name="LiveTcpStateFilterButton" Click="LiveTcpStateFilterButton_Click" Margin="5,0" ToolTip="States Filter" Width="52" Height="52"
                        Visibility="{Binding ToolbarViewType, Converter={StaticResource ToolbarViewTypeToVisibilityConverter}, ConverterParameter=LiveTcp}">
                    <Image Source="{StaticResource StateIconImage}" Width="18" Height="18"/>
                </Button>
                <ToggleButton Name="LiveTcpTcpV4ToggleButton" IsChecked="True" Checked="LiveTcpProtocolToggle_Checked" Unchecked="LiveTcpProtocolToggle_Checked" Margin="5,0" ToolTip="TCP V4" Width="Auto" Height="44" Padding="12,4"
                        Visibility="{Binding ToolbarViewType, Converter={StaticResource ToolbarViewTypeToVisibilityConverter}, ConverterParameter=LiveTcp}">
                    <StackPanel Orientation="Horizontal">
                        <Path Data="{StaticResource TcpIcon}" Stroke="#2B579A" StrokeThickness="2" Width="16" Height="16" Margin="0,0,6,0"/>
                        <TextBlock Text="TCP V4" VerticalAlignment="Center"/>
                    </StackPanel>
                </ToggleButton>
                <ToggleButton Name="LiveTcpTcpV6ToggleButton" IsChecked="True" Checked="LiveTcpProtocolToggle_Checked" Unchecked="LiveTcpProtocolToggle_Checked" Margin="5,0" ToolTip="TCP V6" Width="Auto" Height="44" Padding="12,4"
                        Visibility="{Binding ToolbarViewType, Converter={StaticResource ToolbarViewTypeToVisibilityConverter}, ConverterParameter=LiveTcp}">
                    <StackPanel Orientation="Horizontal">
                        <Path Data="{StaticResource TcpIcon}" Stroke="#2B579A" StrokeThickness="2" Width="16" Height="16" Margin="0,0,6,0"/>
                        <TextBlock Text="TCP V6" VerticalAlignment="Center"/>
                    </StackPanel>
                </ToggleButton>
                <ToggleButton Name="LiveTcpUdpV4ToggleButton" IsChecked="True" Checked="LiveTcpProtocolToggle_Checked" Unchecked="LiveTcpProtocolToggle_Checked" Margin="5,0" ToolTip="UDP V4" Width="Auto" Height="44" Padding="12,4"
                        Visibility="{Binding ToolbarViewType, Converter={StaticResource ToolbarViewTypeToVisibilityConverter}, ConverterParameter=LiveTcp}">
                    <StackPanel Orientation="Horizontal">
                        <Path Data="{StaticResource UdpIcon}" Stroke="#2B579A" StrokeThickness="2" Width="16" Height="16" Margin="0,0,6,0"/>
                        <TextBlock Text="UDP V4" VerticalAlignment="Center"/>
                    </StackPanel>
                </ToggleButton>
                <ToggleButton Name="LiveTcpUdpV6ToggleButton" IsChecked="True" Checked="LiveTcpProtocolToggle_Checked" Unchecked="LiveTcpProtocolToggle_Checked" Margin="5,0" ToolTip="UDP V6" Width="Auto" Height="44" Padding="12,4"
                        Visibility="{Binding ToolbarViewType, Converter={StaticResource ToolbarViewTypeToVisibilityConverter}, ConverterParameter=LiveTcp}">
                    <StackPanel Orientation="Horizontal">
                        <Path Data="{StaticResource UdpIcon}" Stroke="#2B579A" StrokeThickness="2" Width="16" Height="16" Margin="0,0,6,0"/>
                        <TextBlock Text="UDP V6" VerticalAlignment="Center"/>
                    </StackPanel>
                </ToggleButton>

                <!-- Static View Refresh Buttons -->
                <Button Name="StaticProcessRefreshButton" Click="StaticProcessRefreshButton_Click" Margin="5,0" ToolTip="Refresh"
                        Visibility="{Binding ToolbarViewType, Converter={StaticResource ToolbarViewTypeToVisibilityConverter}, ConverterParameter=StaticProcess}">
                    <Path Data="{StaticResource RefreshIcon}" Style="{StaticResource RefreshIconStyle}" Stretch="Uniform"/>
                </Button>
                <Button Name="NetworkRefreshButton" Click="NetworkRefreshButton_Click" Margin="5,0" ToolTip="Refresh"
                        Visibility="{Binding ToolbarViewType, Converter={StaticResource ToolbarViewTypeToVisibilityConverter}, ConverterParameter=Network}">
                    <Path Data="{StaticResource RefreshIcon}" Style="{StaticResource RefreshIconStyle}" Stretch="Uniform"/>
                </Button>
            </ToolBar>
            
            <!-- Shared Content Display Area -->
            <ContentControl Grid.Row="1" Name="SharedContentArea"/>

            <!-- Cache Status & Warnings -->
            <Border Grid.Row="2" Background="#FFF5F7FA" BorderBrush="#FFD0D7E5" BorderThickness="1" Padding="6" Margin="0,5,0,0">
                <StackPanel>
                    <TextBlock Name="CacheStatusTextBlock" FontSize="12" Foreground="#334155" Text="PID Cache: -" />
                    <TextBlock Name="EtwThrottleTextBlock" FontSize="12" Foreground="#334155" Text="ETW Throttle: -" />
                    <TextBlock Name="UiBackpressureTextBlock" FontSize="12" Foreground="#334155" Text="UI Queue: -" />
                    <TextBlock Name="IndexStatusTextBlock" FontSize="12" Foreground="#334155" Text="" Visibility="Collapsed"/>
                    <TextBlock Name="CollectionWarningsTextBlock" FontSize="12" Foreground="#b45309" Text="" Visibility="Collapsed"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
