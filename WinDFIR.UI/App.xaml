<Application x:Class="WinDFIR.UI.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:WinDFIR.UI.Converters"
             ShutdownMode="OnMainWindowClose">
    <Application.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <converters:InverseBooleanToVisibilityConverter x:Key="InverseBooleanToVisibilityConverter"/>
        <converters:ResultSeverityToBrushConverter x:Key="ResultSeverityToBrushConverter"/>
        <converters:ToolbarViewTypeToVisibilityConverter x:Key="ToolbarViewTypeToVisibilityConverter"/>
        <converters:StringToVisibilityConverter x:Key="StringToVisibilityConverter"/>
    </Application.Resources>
</Application>
