<Window x:Class="WinDFIR.UI.Views.CollectionTrustWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Collection Trust"
        Width="640"
        Height="620"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        MinWidth="520"
        MinHeight="420">
    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Overall RAG banner -->
        <Border Grid.Row="0" x:Name="OverallBanner" Padding="16,12">
            <StackPanel>
                <TextBlock x:Name="OverallText" FontSize="20" FontWeight="Bold" Foreground="White"/>
                <TextBlock x:Name="OverallSubText" FontSize="12" Foreground="White" Opacity="0.9" Margin="0,2,0,0" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <!-- Headline metadata -->
        <Border Grid.Row="1" Background="#FFF3F3F3" Padding="16,8" BorderBrush="#FFDDDDDD" BorderThickness="0,0,0,1">
            <TextBlock x:Name="HeadlineText" FontSize="12" Foreground="#FF333333" TextWrapping="Wrap"/>
        </Border>

        <!-- Signals -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Padding="8">
            <ItemsControl x:Name="SignalsList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="6,4" Padding="0" BorderBrush="#FFE0E0E0" BorderThickness="1" CornerRadius="3">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="86"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Background="{Binding BadgeBrush}" CornerRadius="3,0,0,3">
                                    <TextBlock Text="{Binding BadgeText}" Foreground="White" FontWeight="Bold"
                                               FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Grid.Column="1" Margin="10,6">
                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="13"/>
                                    <TextBlock Text="{Binding Detail}" FontSize="12" Foreground="#FF555555"
                                               TextWrapping="Wrap" Margin="0,2,0,0"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Known limitations -->
        <Border Grid.Row="3" x:Name="LimitationsBorder" Background="#FFFAFAFA" Padding="16,8"
                BorderBrush="#FFDDDDDD" BorderThickness="0,1,0,0" Visibility="Collapsed">
            <StackPanel>
                <TextBlock Text="Known limitations (from manifest)" FontWeight="SemiBold" FontSize="12" Margin="0,0,0,4"/>
                <ItemsControl x:Name="LimitationsList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}" FontSize="11" Foreground="#FF555555"
                                       TextWrapping="Wrap" Margin="0,1"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>

        <!-- Buttons -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="12,8">
            <Button Content="Copy summary" Click="CopyButton_Click" Height="30" Width="110" Margin="0,0,8,0"/>
            <Button Content="Close" Click="CloseButton_Click" Height="30" Width="90" IsDefault="True" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
