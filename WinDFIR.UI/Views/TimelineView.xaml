<UserControl x:Class="WinDFIR.UI.Views.TimelineView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:WinDFIR.UI.Converters">
    <UserControl.Resources>
        <converters:TimeZoneDisplayConverter x:Key="TimeZoneDisplayConverter"/>
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="5"/>
            <RowDefinition Height="200"/>
        </Grid.RowDefinitions>

        <!-- Filter Panel -->
        <GroupBox Grid.Row="0" Header="Filters" Margin="5" Padding="5">
            <StackPanel>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="Start:" VerticalAlignment="Center" Margin="5,0"/>
                    <DatePicker Grid.Column="1" Name="StartDatePicker" SelectedDateChanged="StartDatePicker_SelectedDateChanged" Margin="5,0"/>

                    <TextBlock Grid.Column="2" Text="End:" VerticalAlignment="Center" Margin="5,0"/>
                    <DatePicker Grid.Column="3" Name="EndDatePicker" SelectedDateChanged="EndDatePicker_SelectedDateChanged" Margin="5,0"/>

                    <TextBlock Grid.Column="4" Text="Search:" VerticalAlignment="Center" Margin="5,0"/>
                    <TextBox Grid.Column="5" Name="FilterTextBox" Text="{Binding FilterText, UpdateSourceTrigger=PropertyChanged, Delay=300}" Margin="5,0"/>

                    <Button Grid.Column="6" Content="Clear" Click="ClearButton_Click" Margin="5,0"/>
                </Grid>
                <StackPanel Orientation="Horizontal" Margin="5,3,0,0">
                    <TextBlock Text="Time range:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                    <Button Content="Today" Click="TimeRangeToday_Click" Padding="6,2" Margin="0,0,4,0" ToolTip="Set range to today"/>
                    <Button Content="Last 24h" Click="TimeRange24h_Click" Padding="6,2" Margin="0,0,4,0" ToolTip="Last 24 hours"/>
                    <Button Content="Last 7 days" Click="TimeRange7d_Click" Padding="6,2" Margin="0,0,15,0" ToolTip="Last 7 days"/>
                    <Button Content="Export CSV..." Click="ExportCsv_Click" Padding="6,2" Margin="0,0,4,0" ToolTip="Export current events to CSV"/>
                    <Button Content="Export JSON..." Click="ExportJson_Click" Padding="6,2" ToolTip="Export current events to JSON"/>
                </StackPanel>
                <Grid Margin="5,5,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Category:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                    <TextBox Grid.Column="1" Text="{Binding FilterCategory, UpdateSourceTrigger=PropertyChanged, Delay=300}" Margin="0,0,10,0" ToolTip="Filter by category (e.g. File, Registry)"/>
                    <TextBlock Grid.Column="2" Text="Action:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                    <TextBox Grid.Column="3" Text="{Binding FilterAction, UpdateSourceTrigger=PropertyChanged, Delay=300}" Margin="0,0,10,0" ToolTip="Filter by action (e.g. Create, Write)"/>
                    <TextBlock Grid.Column="4" Text="Process:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                    <TextBox Grid.Column="5" Text="{Binding FilterProcessName, UpdateSourceTrigger=PropertyChanged, Delay=300}" Margin="0,0,10,0" ToolTip="Filter by process name"/>
                    <TextBlock Grid.Column="6" Text="Path:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                    <TextBox Grid.Column="7" Text="{Binding FilterPath, UpdateSourceTrigger=PropertyChanged, Delay=300}" ToolTip="Filter by file/path"/>
                </Grid>
                <!-- Drill-down process filter (shown when filtering by process from Live Process) -->
                <StackPanel Orientation="Horizontal" Margin="5,5,0,0" Visibility="{Binding HasProcessFilter, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <TextBlock Text="{Binding ProcessFilterLabel}" VerticalAlignment="Center" Foreground="#2B579A" FontWeight="SemiBold"/>
                    <Button Name="ClearProcessFilterButton" Content="Clear process filter" Click="ClearProcessFilterButton_Click" Margin="10,0,0,0" Padding="6,2"/>
                </StackPanel>
            </StackPanel>
        </GroupBox>

        <!-- Timeline Events (with empty-state message) -->
        <Grid Grid.Row="1">
            <DataGrid Name="TimelineDataGrid"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      GridLinesVisibility="All"
                      SelectionMode="Single"
                      EnableRowVirtualization="True"
                      EnableColumnVirtualization="True"
                      VirtualizingPanel.IsVirtualizing="True"
                      VirtualizingPanel.VirtualizationMode="Recycling"
                      ScrollViewer.CanContentScroll="True"
                      SelectedItem="{Binding SelectedEvent}"
                      SelectionChanged="TimelineDataGrid_SelectionChanged">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Action Time" Width="160">
                    <DataGridTextColumn.Binding>
                        <MultiBinding Converter="{StaticResource TimeZoneDisplayConverter}" StringFormat="{}">
                            <Binding Path="Timestamp"/>
                            <Binding Path="DataContext.UseUtcDisplay" RelativeSource="{RelativeSource AncestorType=UserControl}"/>
                        </MultiBinding>
                    </DataGridTextColumn.Binding>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Action" Binding="{Binding Action}" Width="120"/>
                <DataGridTextColumn Header="Description" Binding="{Binding Summary}" Width="*" MinWidth="200"/>
                <DataGridTextColumn Header="Process/Source" Binding="{Binding SubjectProcess}" Width="150"/>
                <DataGridTextColumn Header="File Path" Binding="{Binding ObjectFile}" Width="200"/>
                <DataGridTextColumn Header="URL" Binding="{Binding ObjectUrl}" Width="200"/>
                <DataGridTextColumn Header="User" Binding="{Binding SubjectUser}" Width="100"/>
                <DataGridTextColumn Header="Data Source" Binding="{Binding Category}" Width="100"/>
            </DataGrid.Columns>
            </DataGrid>
            <TextBlock Text="目前篩選結果為 0 筆，請調整時間範圍或篩選條件。"
                       VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="#64748b" FontSize="14"
                       Visibility="{Binding IsEmpty, Converter={StaticResource BooleanToVisibilityConverter}}"/>
        </Grid>

        <!-- Splitter -->
        <GridSplitter Grid.Row="2" Height="5" HorizontalAlignment="Stretch" Background="#DDDDDD" ShowsPreview="True"/>

        <!-- Event Details -->
        <GroupBox Grid.Row="3" Header="Event Details" Margin="5" Padding="5">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <TextBox Name="DetailsTextBlock"
                         IsReadOnly="True"
                         IsUndoEnabled="False"
                         TextWrapping="Wrap"
                         AcceptsReturn="True"
                         Background="Transparent"
                         BorderThickness="0"
                         FontFamily="Consolas"
                         FontSize="11"
                         Margin="5"
                         VerticalScrollBarVisibility="Disabled"/>
            </ScrollViewer>
        </GroupBox>
    </Grid>
</UserControl>
