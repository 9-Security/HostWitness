<Window x:Class="WinDFIR.UI.Views.LiveTcpStateFilterDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Connection States"
        Width="420"
        Height="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Grid Margin="12">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="120"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Text="Choose which connection states to show:" Margin="0,0,0,8"/>

        <Border Grid.Row="1" Grid.Column="0" BorderBrush="#FFC7C7C7" BorderThickness="1">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding Options}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <CheckBox Content="{Binding Display}" IsChecked="{Binding IsChecked}" Margin="8,4"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <StackPanel Grid.Row="1" Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Top">
            <Button Content="All" Click="AllButton_Click" Margin="0,0,0,8" Height="32"/>
            <Button Content="None" Click="NoneButton_Click" Margin="0,0,0,8" Height="32"/>
            <Button Content="Invert" Click="InvertButton_Click" Margin="0,0,0,16" Height="32"/>
            <Button Content="OK" Click="OkButton_Click" Margin="0,0,0,8" Height="32"/>
            <Button Content="Cancel" Click="CancelButton_Click" Height="32"/>
        </StackPanel>
    </Grid>
</Window>
