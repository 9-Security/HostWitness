<Window x:Class="WinDFIR.UI.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings - HostWitness"
        Height="620" Width="740"
        WindowStartupLocation="CenterOwner">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="16">
            <TextBlock Text="Settings" FontSize="18" FontWeight="Bold" Margin="0,0,0,12"/>
            <GroupBox Header="Profiles" Margin="0,0,0,12">
                <StackPanel Margin="10">
                    <TextBlock Foreground="#475569" TextWrapping="Wrap" Margin="0,0,0,8">
                        套用預設組態：Forensic Strict（離線優先）或 Triage Fast（即時優先）。
                    </TextBlock>
                    <StackPanel Orientation="Horizontal">
                        <Button Content="Apply Forensic Strict" Width="170" Margin="0,0,8,0" Click="ApplyForensicStrict_Click"/>
                        <Button Content="Apply Triage Fast" Width="150" Click="ApplyTriageFast_Click"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                        <Button Content="Export Profile..." Width="170" Margin="0,0,8,0" Click="ExportProfile_Click"/>
                        <Button Content="Import Profile..." Width="150" Click="ImportProfile_Click"/>
                    </StackPanel>
                </StackPanel>
            </GroupBox>

            <GroupBox Header="Font Size" Margin="0,0,0,12">
                <StackPanel Margin="10">
                    <TextBlock Text="{Binding FontSizeModeHelp}" Foreground="#475569" Margin="0,0,0,8" TextWrapping="Wrap"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="介面字型大小" Width="140" VerticalAlignment="Center"/>
                        <ComboBox Width="220"
                                  ItemsSource="{Binding FontSizeOptions}"
                                  SelectedValuePath="Value"
                                  DisplayMemberPath="Label"
                                  SelectedValue="{Binding SelectedFontSizeOption, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                    <TextBlock Text="{Binding CustomFontSizeHelp}" Foreground="#475569" Margin="0,0,0,6" TextWrapping="Wrap"/>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="自訂大小" Width="140" VerticalAlignment="Center"/>
                        <TextBox Width="120"
                                 Text="{Binding CustomFontSize, UpdateSourceTrigger=PropertyChanged}"
                                 IsEnabled="{Binding IsCustomFontSize}"/>
                    </StackPanel>
                </StackPanel>
            </GroupBox>

            <GroupBox Header="Time Zone (Timeline)" Margin="0,0,0,12">
                <StackPanel Margin="10">
                    <TextBlock Text="{Binding TimeZoneDisplayHelp}" Foreground="#475569" Margin="0,0,0,8" TextWrapping="Wrap"/>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="顯示時間" Width="140" VerticalAlignment="Center"/>
                        <ComboBox Width="220"
                                  ItemsSource="{Binding TimeZoneDisplayOptions}"
                                  SelectedValuePath="Value"
                                  DisplayMemberPath="Label"
                                  SelectedValue="{Binding SelectedTimeZoneDisplay, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                </StackPanel>
            </GroupBox>

            <GroupBox Header="Registry (鑑識)" Margin="0,0,0,12">
                <StackPanel Margin="10">
                    <TextBlock Foreground="#475569" Margin="0,0,0,6" TextWrapping="Wrap">
                        <Run Text="鑑識模式：勾選「僅離線登錄檔」時，僅使用 Offline Hive（不含 Live Registry）；可減少對 Win32 API 依賴。重啟後生效。"/>
                    </TextBlock>
                    <TextBlock Text="{Binding RegistryUseOfflineOnlyHelp}" Foreground="#64748b" Margin="0,0,0,6" TextWrapping="Wrap"/>
                    <CheckBox Content="僅離線登錄檔 (Registry use offline only)" IsChecked="{Binding RegistryUseOfflineOnly, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,0"/>
                    <TextBlock Text="{Binding EnableLiveRegistryExperimentalHelp}" Foreground="#64748b" Margin="0,8,0,4" TextWrapping="Wrap"/>
                    <CheckBox Content="允許 Live Registry（實驗性，non-forensic）"
                              IsChecked="{Binding EnableLiveRegistryExperimental, UpdateSourceTrigger=PropertyChanged}"/>
                    <TextBlock Foreground="#64748b" Margin="0,6,0,0" TextWrapping="Wrap" FontSize="12">
                        <Run Text="說明："/>
                        <Hyperlink NavigateUri="docs/RegistrySearch說明.md" RequestNavigate="RegistryHelpLink_RequestNavigate">
                            <Run Text="Registry Search 說明"/>
                        </Hyperlink>
                        <Run Text="、TECH_DEBT（僅離線模式）。"/>
                    </TextBlock>
                </StackPanel>
            </GroupBox>

            <GroupBox Header="Raw Disk (Offline Hive)" Margin="0,0,0,12">
                <StackPanel Margin="10">
                    <TextBlock Foreground="#475569" Margin="0,0,0,6" TextWrapping="Wrap">
                        <Run Text="從實體磁碟讀取 Hive（需管理員）。每行一筆：DriveNumber,OffsetBytes,SizeBytes,HiveName（例：0,0,409600,SYSTEM）。重啟後生效。"/>
                    </TextBlock>
                    <TextBox Text="{Binding RawHiveSourcesText, UpdateSourceTrigger=PropertyChanged}" Height="80" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" Margin="0,0,0,4"/>
                </StackPanel>
            </GroupBox>

            <GroupBox Header="Export" Margin="0,0,0,12">
                <StackPanel Margin="10">
                    <TextBlock Text="Default directory for export dialogs (Timeline CSV/JSON, etc.). Leave empty for system default." Foreground="#475569" Margin="0,0,0,6" TextWrapping="Wrap"/>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Export default path" Width="140" VerticalAlignment="Center"/>
                        <TextBox Text="{Binding ExportDefaultDirectory, UpdateSourceTrigger=PropertyChanged}" Width="320" Margin="0,0,8,0"/>
                    </StackPanel>
                </StackPanel>
            </GroupBox>

            <GroupBox Header="Activity Index (Timeline)" Margin="0,0,0,12">
                <StackPanel Margin="10">
                    <TextBlock Text="{Binding IndexMaxEventsHelp}" Foreground="#475569" Margin="0,0,0,8" TextWrapping="Wrap"/>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Max events in memory" Width="160" VerticalAlignment="Center"/>
                        <TextBox Text="{Binding IndexMaxEvents, UpdateSourceTrigger=PropertyChanged}" Width="120"/>
                        <TextBlock Text="(0 = unbounded)" VerticalAlignment="Center" Margin="8,0,0,0" Foreground="#64748b"/>
                    </StackPanel>
                    <TextBlock Text="{Binding IndexMaxEventsUnboundedWarning}" Foreground="#b45309" Margin="0,6,0,0" TextWrapping="Wrap" Visibility="{Binding IndexMaxEventsUnboundedWarning, Converter={StaticResource StringToVisibilityConverter}}"/>
                </StackPanel>
            </GroupBox>

            <GroupBox Header="Status Bar Diagnostics" Margin="0,0,0,12">
                <StackPanel Margin="10">
                    <TextBlock Text="{Binding ShowStatusBarDiagnosticsHelp}" Foreground="#475569" Margin="0,0,0,8" TextWrapping="Wrap"/>
                    <CheckBox Content="顯示狀態列診斷資訊（PID Cache / ETW Throttle / UI Queue）"
                              IsChecked="{Binding ShowStatusBarDiagnostics, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>
            </GroupBox>

            <TextBlock Text="PID Cache Settings" FontSize="16" FontWeight="Bold" Margin="0,0,0,12"/>

            <GroupBox Header="EventLog Cache" Margin="0,0,0,12">
                <StackPanel Margin="10">
                    <TextBlock Text="{Binding EventLogHelp}" Foreground="#475569" Margin="0,0,0,8" TextWrapping="Wrap"/>
                    <UniformGrid Columns="3" Margin="0,0,0,6">
                        <TextBlock Text="Provisional TTL (min)" VerticalAlignment="Center"/>
                        <TextBlock Text="Authoritative TTL (min)" VerticalAlignment="Center"/>
                        <TextBlock Text="Max Entries (LRU)" VerticalAlignment="Center"/>
                    </UniformGrid>
                    <UniformGrid Columns="3">
                        <TextBox Text="{Binding EventLogProvisionalTtlMinutes, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,8,0"/>
                        <TextBox Text="{Binding EventLogAuthoritativeTtlMinutes, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,8,0"/>
                        <TextBox Text="{Binding EventLogMaxEntries, UpdateSourceTrigger=PropertyChanged}"/>
                    </UniformGrid>
                </StackPanel>
            </GroupBox>

            <GroupBox Header="ETW Cache" Margin="0,0,0,12">
                <StackPanel Margin="10">
                    <TextBlock Text="{Binding EtwHelp}" Foreground="#475569" Margin="0,0,0,8" TextWrapping="Wrap"/>
                    <UniformGrid Columns="3" Margin="0,0,0,6">
                        <TextBlock Text="Provisional TTL (min)" VerticalAlignment="Center"/>
                        <TextBlock Text="Authoritative TTL (min)" VerticalAlignment="Center"/>
                        <TextBlock Text="Max Entries (LRU)" VerticalAlignment="Center"/>
                    </UniformGrid>
                    <UniformGrid Columns="3">
                        <TextBox Text="{Binding EtwProvisionalTtlMinutes, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,8,0"/>
                        <TextBox Text="{Binding EtwAuthoritativeTtlMinutes, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,8,0"/>
                        <TextBox Text="{Binding EtwMaxEntries, UpdateSourceTrigger=PropertyChanged}"/>
                    </UniformGrid>
                    <TextBlock Text="{Binding EtwThrottleMaxPerSecondHelp}" Foreground="#475569" Margin="0,10,0,6" TextWrapping="Wrap"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <TextBlock Text="Throttle cap (events/s)" VerticalAlignment="Center" Width="160"/>
                        <TextBox Text="{Binding EtwThrottleMaxPerSecond, UpdateSourceTrigger=PropertyChanged}" Width="120" Margin="0,0,8,0"/>
                        <TextBlock Text="(0 = built-in defaults)" VerticalAlignment="Center" Foreground="#64748b"/>
                    </StackPanel>
                    <TextBlock Foreground="#b45309" TextWrapping="Wrap" Margin="0,2,0,0">
                        <Run Text="Raising the cap may increase CPU and memory use. Restart to apply."/>
                    </TextBlock>
                </StackPanel>
            </GroupBox>

            <GroupBox Header="Long-lived Processes" Margin="0,0,0,12">
                <StackPanel Margin="10">
                    <TextBlock Text="{Binding LongLivedTtlHelp}" Foreground="#475569" Margin="0,0,0,6" TextWrapping="Wrap"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="Long-lived TTL (min)" VerticalAlignment="Center" Width="160"/>
                        <TextBox Text="{Binding LongLivedTtlMinutes, UpdateSourceTrigger=PropertyChanged}" Width="120"/>
                    </StackPanel>

                    <TextBlock Text="{Binding LongLivedNamesHelp}" Foreground="#475569" Margin="0,0,0,6" TextWrapping="Wrap"/>
                    <TextBox Text="{Binding LongLivedProcessNamesText, UpdateSourceTrigger=PropertyChanged}" Height="120" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"/>
                </StackPanel>
            </GroupBox>

            <GroupBox Header="Notes" Margin="0,0,0,16">
                <ItemsControl ItemsSource="{Binding Notes}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <TextBlock TextWrapping="Wrap" Foreground="#475569">
                                <Run Text="- "/>
                                <Run Text="{Binding Path=., Mode=OneWay}"/>
                            </TextBlock>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </GroupBox>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Cancel" Width="90" Margin="0,0,8,0" Click="Cancel_Click"/>
                <Button Content="Save" Width="90" Click="Save_Click"/>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Window>
